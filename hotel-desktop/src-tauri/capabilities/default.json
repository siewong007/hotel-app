{
  "$schema": "https://schemas.tauri.app/2/capabilities",
  "identifier": "default",
  "description": "Default capabilities for the Hotel Management System",
  "windows": ["main"],
  "remote": {
    "urls": [
      "http://localhost:3000/*",
      "http://127.0.0.1:3000/*"
    ]
  },
  "permissions": [
    "core:default",
    "shell:default",
    "shell:allow-open",
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:allow-kill",
    "shell:allow-stdin-write"
  ]
}
