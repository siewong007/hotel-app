Name: libpq
Description: PostgreSQL libpq library
Url: https://www.postgresql.org/
Version: 14.19
Requires: 
Requires.private: libssl libcrypto
Cflags: -I/opt/homebrew/include/postgresql@14
Libs: -L/opt/homebrew/lib/postgresql@14 -lpq
Libs.private: -L/opt/homebrew/opt/lz4/lib -L/opt/homebrew/opt/openssl@3/lib -L/opt/homebrew/opt/readline/lib -lpgcommon -lpgport -lgssapi_krb5 -lm -lldap_r
