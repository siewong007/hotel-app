{
  "name": "hotel-desktop",
  "version": "1.0.0",
  "description": "Hotel Management System - Desktop Application",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build",
    "build:debug": "tauri build --debug",
    "sync:resources": "node scripts/sync-desktop-resources.mjs",
    "build:frontend": "npm --prefix ../hotel-web-fe run build",
    "build:backend": "cargo build --manifest-path ../hotel-app-be/Cargo.toml --release",
    "copy:backend": "node scripts/copy-backend-sidecar.mjs",
    "desktop:prepare": "npm run sync:resources && npm run build:frontend && npm run build:backend && npm run copy:backend"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@tauri-apps/api": "^2"
  }
}
