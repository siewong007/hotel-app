ENVIRONMENT=development
POSTGRES_USER=hotel_admin
POSTGRES_PASSWORD=hotel_admin_password
POSTGRES_DB=hotel_management
POSTGRES_PORT=5432
DATABASE_URL=postgres://hotel_admin:hotel_admin_password@localhost:5432/hotel_management
DATABASE_MAX_CONNECTIONS=10
BACKEND_PORT=3030
BACKEND_HOST=0.0.0.0
JWT_SECRET=local_dev_jwt_secret_key_min_32_chars_long
JWT_EXPIRATION=3600
REFRESH_TOKEN_EXPIRATION=604800
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
RUST_LOG=debug
RUST_BACKTRACE=1
